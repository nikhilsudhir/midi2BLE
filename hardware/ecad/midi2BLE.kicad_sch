				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "4c3cb664-14d8-4b9c-9bbb-ae250862f5d9")
	)
	(text_box "Port definitions\n\nUpstream USB-C:\n- Charging input\n- Computer connection in passthrough mode\n\nKeyboard USB-C:\n- MIDI controller connection\n- Routed to ESP32 in wireless mode\n- Routed to upstream USB-C in passthrough mode"
		(exclude_from_sim no)
		(at 210.82 74.93 0)
		(size 53.34 22.35)
		(margins 0.9525 0.9525 0.9525 0.9525)
