	)
	(text_box "MODE_SEL truth table\n\nMODE_SEL = 1  -> WIRELESS\n- USB data: Keyboard <-> ESP32\n- Keyboard VBUS: BOOST_5V\n- BLE: ON\n- USB host: ON\n\nMODE_SEL = 0  -> PASSTHROUGH\n- USB data: Keyboard <-> Upstream USB-C (direct passthrough)\n- Keyboard VBUS: VBUS_IN\n- BLE: OFF\n- USB host: OFF"
		(exclude_from_sim no)
		(at 213.36 14.6962 0)
		(size 68.58 30.5285)
		(margins 0.9525 0.9525 0.9525 0.9525)
		(stroke
			(width 0)
			(type solid)
