	(text_box "Wireless MIDI Bridge V1\nTop-Level System Architechture\n\nModes\n- Wireless BLE MIDI Bridge\n- Wired USB pasthrough"
		(exclude_from_sim no)
		(at 129.54 15.24 0)
		(size 33.02 14.1714)
		(margins 0.9525 0.9525 0.9525 0.9525)
